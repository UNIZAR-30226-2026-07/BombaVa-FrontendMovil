<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="@color/colorPrimary"> <ImageView
    android:layout_width="100dp"
    android:layout_height="100dp"
    android:src="@android:drawable/ic_menu_compass"
    app:tint="@color/wood_btn"
    android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_auth_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CENTRO DE MANDO"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/et_username"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Nombre de usuario"
        android:textColorHint="#000000"
        android:textColor="#3A3737"
        android:background="@drawable/bg_input_naval"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textPersonName"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/et_email"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Correo Electrónico"
        android:visibility="gone"
        android:textColorHint="#000000"
        android:textColor="#3A3737"
        android:background="@drawable/bg_input_naval"
        android:paddingStart="16dp"
        android:layout_marginBottom="16dp"
        android:inputType="textEmailAddress" />

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Código de autorización"
        android:textColorHint="@color/black"
        android:textColor="#3A3737"
        android:background="@drawable/bg_input_naval"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textPassword"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_auth_action"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="ENTRAR A LA FLOTA"
        android:textSize="16sp"
        android:textColor="#0B132B"
        android:textStyle="bold"
        android:background="@drawable/bg_boton_flota"
        app:backgroundTint="@null" /> <TextView
        android:id="@+id/tv_toggle_auth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿No tienes cuenta? Regístrate aquí"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginTop="32dp"
        android:padding="8dp" />

</LinearLayout>