<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ocean_dark_bg"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"> <ImageView
    android:layout_width="160dp"
    android:layout_height="160dp"
    android:src="@drawable/img_almirante_tallado"
    android:contentDescription="Retrato tallado del Almirante"
    android:layout_marginTop="32dp"
    android:scaleType="centerInside" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HOJA DE SERVICIOS"
        android:textColor="@color/wood_top_highlight"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_tablero_madera"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:elevation="8dp"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALMIRANTE"
            android:textColor="@color/wood_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/tv_perfil_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando..."
            android:textColor="@color/wood_dark_shadow"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_perfil_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comunicaciones..."
            android:textColor="@color/wood_text_color"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_perfil_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conectando..."
            android:textColor="@color/teal_700"
            android:textSize="16sp"
            android:textStyle="italic"
            android:gravity="center"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_sala_mando"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="IR A LA SALA DE MANDO"
        android:textSize="18sp"
        android:backgroundTint="@color/wood_btn"
        android:textColor="@color/wood_dark"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_cerrar_sesion"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="CERRAR SESIÓN"
        android:textSize="16sp"
        android:backgroundTint="#D02204"
        android:textColor="@color/colorPrimary"
        android:textStyle="bold"/>

</LinearLayout>