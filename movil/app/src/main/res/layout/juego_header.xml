<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/wooden_style"
    android:padding="16dp"
    android:elevation="8dp">

    <TextView
        android:id="@+id/tvTurnoDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Turno 7 - "
        android:textColor="#E0E0E0"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnPasarTurno"
        app:layout_constraintBottom_toBottomOf="@+id/btnPasarTurno"/>

    <TextView
        android:id="@+id/txtTurnoStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONECTANDO..."
        tools:text="TU TURNO"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="4dp"
        app:layout_constraintStart_toEndOf="@id/tvTurnoDisplay"
        app:layout_constraintTop_toTopOf="@id/tvTurnoDisplay"
        app:layout_constraintBottom_toBottomOf="@id/tvTurnoDisplay"/>

    <Button
        android:id="@+id/btnPasarTurno"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pasar Turno"
        android:backgroundTint="#424242"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPasarTurno"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/lblFuel"
        android:layout_width="125dp"
        android:layout_height="wrap_content"
        android:text="⛽ Combustible:"
        android:textColor="#FF8A80"
        android:textSize="15sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/barFuel"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:progress="10"
        android:max="10"
        android:progressTint="#FF5252"
        android:progressBackgroundTint="#66000000"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/lblFuel"
        app:layout_constraintEnd_toStartOf="@id/txtFuel"
        app:layout_constraintTop_toTopOf="@id/lblFuel"
        app:layout_constraintBottom_toBottomOf="@id/lblFuel" />

    <TextView
        android:id="@+id/txtFuel"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="0"
        tools:text="10"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="end"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toStartOf="@id/btnPause"
        app:layout_constraintTop_toTopOf="@id/lblFuel"
        app:layout_constraintBottom_toBottomOf="@id/lblFuel"/>

    <TextView
        android:id="@+id/lblAmmo"
        android:layout_width="125dp"
        android:layout_height="wrap_content"
        android:text="⚔️ Munición:"
        android:textColor="#B9F6CA"
        android:textSize="15sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/lblFuel"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/barAmmo"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:progress="10"
        android:max="10"
        android:progressTint="#4CAF50"
        android:progressBackgroundTint="#66000000"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/lblAmmo"
        app:layout_constraintEnd_toStartOf="@id/txtAmmo"
        app:layout_constraintTop_toTopOf="@id/lblAmmo"
        app:layout_constraintBottom_toBottomOf="@id/lblAmmo" />

    <TextView
        android:id="@+id/txtAmmo"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="0"
        tools:text="10"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="end"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toStartOf="@id/btnPause"
        app:layout_constraintTop_toTopOf="@id/lblAmmo"
        app:layout_constraintBottom_toBottomOf="@id/lblAmmo"/>

    <ImageButton
        android:id="@+id/btnPause"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/wooden_style"
        android:src="@android:drawable/ic_media_pause"
        app:tint="@color/wood_dark"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>